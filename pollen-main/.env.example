# Optional path overrides for PyPollen (Scripts/config.py).
# Copy to .env and adjust if your files live outside the defaults.
# The defaults resolve relative to the repository, so you usually need none of these.

# Trained SVM error-prediction model (.sav)
# PYPOLLEN_MODEL_PATH=Analysis Notebooks/Machine Learning/SVM_error_prediction_model.sav

# CSV of manual grain counts/sizes for optimise_segmentation_variables
# Columns (no header): Image,count,size,mag
# PYPOLLEN_TRUE_VALUES=true_values.csv

# Folder of input microscopy images for the __main__ demo run
# PYPOLLEN_INPUT_FOLDER=images
